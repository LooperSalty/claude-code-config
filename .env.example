# =========================================================================
# Secrets requis pour la config Claude Code (ANAKIN / LooperSalty)
# Copier ce fichier en `.env` et renseigner les valeurs reelles.
# `.env` est gitignore - NE JAMAIS le committer.
# Sur Windows, definir ces variables dans l'environnement utilisateur :
#   [Environment]::SetEnvironmentVariable("FIGMA_ACCESS_TOKEN","xxx","User")
# =========================================================================

# Figma - serveur MCP figma (designs -> code)
# Creer un token : https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=

# fal.ai - generation media IA (image/video/audio)
# Cle API : https://fal.ai/dashboard/keys
FAL_KEY=

# Roblox Open Cloud - serveur MCP robloxstudio communautaire
# Creer une cle : https://create.roblox.com/dashboard/credentials
ROBLOX_OPEN_CLOUD_API_KEY=

# GitHub PAT - serveur MCP github (scope: repo, read:org)
# Creer un token : https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=
